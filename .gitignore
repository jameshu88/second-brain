# Private vault — never commit real notes
/vault/

# Obsidian workspace state (machine-local; users will create their own)
/.obsidian/

# Secrets and local config (do not use blanket `.env.*` — that hides `.env.example`)
.env
.env.local
.env.*.local

# brain service local state
services/brain/.env
services/brain/.state/
services/brain/node_modules/

# Dependencies
node_modules/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
